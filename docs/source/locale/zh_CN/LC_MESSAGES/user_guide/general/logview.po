msgid "Sub DAG submission time."
msgstr "Sub DAG 提交时间。"

#: ../../source/user_guide/general/logview.rst:1
msgid "Sub DAG completion time."
msgstr "Sub DAG 完成时间。"

#: ../../source/user_guide/general/logview.rst:1
msgid "Sub DAG runtime."
msgstr "Sub DAG 运行耗时。"

#: ../../source/user_guide/general/logview.rst:1
msgid "Timeline"
msgstr ""

