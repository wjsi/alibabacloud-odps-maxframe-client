msgid ""
"Number of ODPS instances in different states inside the current Sub DAG. "
"``(+X Fallback)`` means X instances were downgraded from MCQA to Offline "
"SQL — the data is not corrupted."
msgstr ""
"当前 Sub DAG 中不同状态的 ODPS instance 数量。``(+X Fallback)`` 表示 X 个"
" instance 从 MCQA 降级到 Offline SQL，数据不会损坏。"

#: ../../source/user_guide/general/logview.rst:1
msgid "Sub DAG status: Failed / Cancelled / Running / Succeeded."
msgstr "Sub DAG 状态：Failed / Cancelled / Running / Succeeded。"

