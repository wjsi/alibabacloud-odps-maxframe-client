msgid "Sub DAG"
msgstr ""

#: ../../source/user_guide/general/logview.rst:1
msgid "Name of the current Sub DAG."
msgstr "当前 Sub DAG 的名称。"

#: ../../source/user_guide/general/logview.rst:1
msgid "Failed/Terminated/ALL"
msgstr ""

